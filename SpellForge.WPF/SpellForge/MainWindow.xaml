<Window x:Class="SpellForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SpellForge.Views.Controls"
        Title="SpellForge" Height="800" Width="1400"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PaneHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontStyle"  Value="Italic"/>
            <Setter Property="Margin"     Value="0,4,0,4"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ── Menu bar ──────────────────────────────────────────── -->
        <Menu DockPanel.Dock="Top" Background="#0d0d1a" Foreground="{StaticResource TextBrush}">
            <MenuItem Header="_File" Foreground="{StaticResource TextBrush}">
                <MenuItem Header="_New Spell"  Command="{Binding NewSpellCommand}"/>
                <MenuItem Header="_Open…"      Command="{Binding OpenSpellCommand}"/>
                <MenuItem Header="_Save"       Command="{Binding SaveSpellCommand}"/>
                <MenuItem Header="Save _As…"   Command="{Binding SaveAsSpellCommand}"/>
                <Separator/>
                <MenuItem Header="Export _PNG…"      Click="MenuSavePng_Click"/>
                <MenuItem Header="Copy _Image"       Click="MenuCopyCanvas_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_View" Foreground="{StaticResource TextBrush}">
                <MenuItem Header="Zoom In"    Command="{Binding ZoomInCommand}"/>
                <MenuItem Header="Zoom Out"   Command="{Binding ZoomOutCommand}"/>
                <MenuItem Header="Reset View" Command="{Binding ZoomResetCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ── Status bar ────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Background="#0d0d1a">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource DimBrush}" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Three-pane layout ─────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"   MinWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="420" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANE ── school/element/identity tabs -->
            <Border Grid.Column="0" Background="{StaticResource PanelBgBrush}">
                <TabControl x:Name="LeftTabs" Background="{StaticResource PanelBgBrush}">
                    <!-- Identity tab -->
                    <TabItem Header="Identity">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8" Background="{StaticResource PanelBgBrush}">
                                <TextBlock Text="✦  Spell Identity" Style="{StaticResource PaneHeader}"/>
                                <TextBlock Text="Name" Foreground="{StaticResource DimBrush}" Margin="0,4,0,2"/>
                                <TextBox Text="{Binding Spell.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                                <TextBlock Text="Description" Foreground="{StaticResource DimBrush}" Margin="0,0,0,2"/>
                                <TextBox Text="{Binding Spell.Description, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>

                                <!-- ── Attrition type ─────────────────────────────── -->
                                <TextBlock Text="Attrition on Hit"
                                           Foreground="{StaticResource DimBrush}" Margin="0,0,0,2"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" Width="110"
                                              ItemsSource="{Binding AttritionTypeOptions}"
                                              SelectedItem="{Binding Spell.AttritionType, Mode=TwoWay}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedAttritionDef.Desc}"
                                               FontSize="9" FontStyle="Italic"
                                               Foreground="{StaticResource DimBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>

                                <TextBlock Text="Spell Effects" Style="{StaticResource PaneHeader}"/>
                                <Border BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" Padding="4">
                                    <TextBlock Text="{Binding SpellEffectsSummary}"
                                               TextWrapping="Wrap" FontFamily="Courier New" FontSize="10"
                                               Foreground="{StaticResource DimBrush}"/>
                                </Border>

                                <!-- ── If-Then conditions ────────────────── -->
                                <TextBlock Text="▸  If-Then Conditions" Style="{StaticResource PaneHeader}"
                                           Margin="0,12,0,4"/>
                                <ItemsControl ItemsSource="{Binding Spell.IfThenConditions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock FontSize="9" Foreground="{StaticResource DimBrush}"
                                                               TextWrapping="Wrap">
                                                        <Run Text="IF "  Foreground="#88aaff" FontWeight="Bold"/>
                                                        <Run Text="{Binding IfOrWhenText}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="9" Foreground="{StaticResource DimBrush}"
                                                               TextWrapping="Wrap" Margin="8,0,0,0">
                                                        <Run Text="THEN " Foreground="{StaticResource GoldBrush}" FontWeight="Bold"/>
                                                        <Run Text="{Binding ThenText}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="✕" Width="20" Height="20"
                                                        Padding="0" VerticalAlignment="Top"
                                                        Command="{Binding DataContext.RemoveIfThenCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Add If-Then row -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="IF"
                                               Foreground="#88aaff" FontWeight="Bold" FontSize="9"
                                               VerticalAlignment="Center" Margin="0,0,6,2"/>
                                    <TextBox  Grid.Row="0" Grid.Column="1"
                                              Text="{Binding NewIfText, UpdateSourceTrigger=PropertyChanged}"
                                              FontSize="10" Margin="0,0,0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="THEN"
                                               Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="9"
                                               VerticalAlignment="Center" Margin="0,0,6,4"/>
                                    <TextBox  Grid.Row="1" Grid.Column="1"
                                              Text="{Binding NewThenText, UpdateSourceTrigger=PropertyChanged}"
                                              FontSize="10" Margin="0,0,0,4"/>
                                    <Button   Grid.Row="2" Grid.Column="1"
                                              Content="+ Add" FontSize="9"
                                              HorizontalAlignment="Left" Padding="6,1"
                                              Command="{Binding AddIfThenCommand}"/>
                                </Grid>

                                <!-- ── When-Then conditions ──────────────── -->
                                <TextBlock Text="▸  When-Then Conditions" Style="{StaticResource PaneHeader}"
                                           Margin="0,12,0,4"/>
                                <ItemsControl ItemsSource="{Binding Spell.WhenThenConditions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="24"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock FontSize="9" Foreground="{StaticResource DimBrush}"
                                                               TextWrapping="Wrap">
                                                        <Run Text="WHEN " Foreground="#88ffcc" FontWeight="Bold"/>
                                                        <Run Text="{Binding IfOrWhenText}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="9" Foreground="{StaticResource DimBrush}"
                                                               TextWrapping="Wrap" Margin="8,0,0,0">
                                                        <Run Text="THEN " Foreground="{StaticResource GoldBrush}" FontWeight="Bold"/>
                                                        <Run Text="{Binding ThenText}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Grid.Column="1" Content="✕" Width="20" Height="20"
                                                        Padding="0" VerticalAlignment="Top"
                                                        Command="{Binding DataContext.RemoveWhenThenCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Add When-Then row -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="WHEN"
                                               Foreground="#88ffcc" FontWeight="Bold" FontSize="9"
                                               VerticalAlignment="Center" Margin="0,0,6,2"/>
                                    <TextBox  Grid.Row="0" Grid.Column="1"
                                              Text="{Binding NewWhenText, UpdateSourceTrigger=PropertyChanged}"
                                              FontSize="10" Margin="0,0,0,2"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="THEN"
                                               Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="9"
                                               VerticalAlignment="Center" Margin="0,0,6,4"/>
                                    <TextBox  Grid.Row="1" Grid.Column="1"
                                              Text="{Binding NewWThenText, UpdateSourceTrigger=PropertyChanged}"
                                              FontSize="10" Margin="0,0,0,4"/>
                                    <Button   Grid.Row="2" Grid.Column="1"
                                              Content="+ Add" FontSize="9"
                                              HorizontalAlignment="Left" Padding="6,1"
                                              Command="{Binding AddWhenThenCommand}"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- School tabs — one per school, populated in code-behind -->
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#1a2a3a"/>

            <!-- CENTRE PANE ── Magic circle canvas -->
            <Grid Grid.Column="2" Background="#1a1208">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Zoom toolbar -->
                <Border Grid.Row="0" Background="#0d0d1a"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,0,0,1"
                        Padding="6,3">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="−" Command="{Binding ZoomOutCommand}"
                                Width="28" Padding="0" FontSize="14"
                                Margin="2,0" ToolTip="Zoom Out (scroll wheel)"/>
                        <Button Content="Reset" Command="{Binding ZoomResetCommand}"
                                Padding="10,2" FontSize="10"
                                Margin="4,0" ToolTip="Reset to 1×"/>
                        <Button Content="+" Command="{Binding ZoomInCommand}"
                                Width="28" Padding="0" FontSize="14"
                                Margin="2,0" ToolTip="Zoom In (scroll wheel)"/>
                    </StackPanel>
                </Border>

                <!-- Canvas -->
                <controls:MagicCircleCanvas Grid.Row="1" x:Name="MagicCanvas"
                                             Spell="{Binding Spell}"
                                             ClipToBounds="True"/>
            </Grid>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="#1a2a3a"/>

            <!-- RIGHT PANE ── Calculator / Modifiers / Synergies / etc. -->
            <Border Grid.Column="4" Background="{StaticResource PanelBgBrush}">
                <TabControl Background="{StaticResource PanelBgBrush}">
                    <TabItem Header="✦ Calculator">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="⊕  Spell Calculator" Style="{StaticResource PaneHeader}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBlock Text="Total Points: " Foreground="{StaticResource DimBrush}"/>
                                    <TextBlock Text="{Binding Spell.TotalPoints}" FontWeight="Bold"
                                               Foreground="{StaticResource GoldBrush}" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Text="Spell Level: " Foreground="{StaticResource DimBrush}"/>
                                    <TextBlock Text="{Binding Spell.LevelName}" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                                <ProgressBar Value="{Binding Spell.LevelProgress, Mode=OneWay}" Maximum="100"
                                             Height="12" Margin="0,6,0,0"
                                             Background="{StaticResource EBgBrush}"
                                             Foreground="{StaticResource AccentBrush}"/>
                                <!-- ── Limits ───────────────────────────── -->
                                <TextBlock Text="Limits" Style="{StaticResource PaneHeader}" Margin="0,12,0,4"/>

                                <!-- Ring mod budget row -->
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Ring Mods" Foreground="{StaticResource DimBrush}"
                                               FontSize="10" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Spell.TotalRingMods}" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text=" / " FontSize="10"
                                                   Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Spell.RingModCap}" FontSize="10"
                                                   Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <ProgressBar Value="{Binding Spell.TotalRingMods, Mode=OneWay}"
                                             Maximum="{Binding Spell.RingModCap, Mode=OneWay}"
                                             Height="5" Margin="0,2,0,6"
                                             Background="{StaticResource EBgBrush}"
                                             Foreground="#8888ff"/>

                                <!-- School count row -->
                                <Grid Margin="0,2,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Schools" Foreground="{StaticResource DimBrush}"
                                               FontSize="10" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Spell.AllSchools.Count}" FontSize="10" FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text=" / 3" FontSize="10"
                                                   Foreground="{StaticResource DimBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- All-OK indicator -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                            Visibility="{Binding NoWarningsVisibility}">
                                    <TextBlock Text="✓  All limits OK" FontSize="10"
                                               Foreground="#66cc88"/>
                                </StackPanel>

                                <!-- Validation warnings -->
                                <ItemsControl ItemsSource="{Binding Spell.ValidationWarnings}"
                                              Visibility="{Binding ValidationWarningsVisibility}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#40220000" CornerRadius="2"
                                                    Margin="0,2" Padding="5,3">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⚠ " Foreground="#ff6666" FontSize="10"/>
                                                    <TextBlock Text="{Binding}" Foreground="#ff8888"
                                                               FontSize="10" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- ── Level Thresholds ──────────────────── -->
                                <TextBlock Text="Level Thresholds" Style="{StaticResource PaneHeader}" Margin="0,12,0,4"/>
                                <ItemsControl ItemsSource="{Binding LevelThresholds}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                <TextBlock Text="{Binding Range}" Width="70"
                                                           Foreground="{StaticResource DimBrush}" FontSize="10"/>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="{Binding ColorBrush}" FontSize="10"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Modifiers">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Content="+ Custom Mod"
                                    Command="{Binding AddCustomModCommand}"
                                    HorizontalAlignment="Right"
                                    Margin="4,4,4,2" Padding="6,2" FontSize="10"/>
                            <controls:GlobalModPanel Grid.Row="1" x:Name="ModPanel" Margin="4,2,4,4"/>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Synergies">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <TextBlock Text="⚜  School Synergies" Style="{StaticResource PaneHeader}"/>
                                <ItemsControl ItemsSource="{Binding ActiveSynergies}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Header}" FontWeight="Bold"
                                                           Foreground="{Binding ColorBrush}" FontSize="10"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="{StaticResource DimBrush}"
                                                           FontSize="9" TextWrapping="Wrap" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Drawbacks">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Content="✎ Manage Drawbacks"
                                    Command="{Binding ManageDrawbacksCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="8,4,8,2" Padding="6,2" FontSize="10"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="8">
                                    <TextBlock Text="◌  Active Drawbacks" Style="{StaticResource PaneHeader}"/>
                                    <ItemsControl ItemsSource="{Binding ActiveDrawbacks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                    <TextBlock Text="◌ " Foreground="#aaaacc" FontSize="10"/>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{StaticResource DimBrush}"
                                                               FontSize="10" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Guide">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding GuideText}" Margin="8"
                                       TextWrapping="Wrap" FontFamily="Courier New" FontSize="9"
                                       Foreground="{StaticResource DimBrush}"/>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Library">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <!-- Schools -->
                                <TextBlock Text="◈  Schools" Style="{StaticResource PaneHeader}"/>
                                <ItemsControl ItemsSource="{Binding LibrarySchools}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,2" Padding="5"
                                                    Background="{StaticResource EBgBrush}"
                                                    CornerRadius="2">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Symbol}"
                                                                   FontSize="14" Margin="0,0,5,0"
                                                                   Foreground="{Binding ColorBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="{Binding ColorBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Desc}"
                                                               FontSize="8" FontStyle="Italic"
                                                               Foreground="{StaticResource DimBrush}"
                                                               TextWrapping="Wrap" Margin="0,1,0,0"/>
                                                    <TextBlock Text="{Binding AbilityList}"
                                                               FontSize="8"
                                                               Foreground="{StaticResource DimBrush}"
                                                               TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Capstones -->
                                <TextBlock Text="⚜  Capstones" Style="{StaticResource PaneHeader}"
                                           Margin="0,10,0,4"/>
                                <ItemsControl ItemsSource="{Binding LibraryCapstones}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,2" Padding="5"
                                                    Background="{StaticResource EBgBrush}"
                                                    CornerRadius="2">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Glyph}"
                                                                   FontSize="14" Margin="0,0,5,0"
                                                                   Foreground="{Binding ColorBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding SchoolName}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="{Binding ColorBrush}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Desc}"
                                                               FontSize="8" FontStyle="Italic"
                                                               Foreground="{StaticResource DimBrush}"
                                                               TextWrapping="Wrap" Margin="0,1,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </DockPanel>
</Window>
