<Window x:Class="SpellForge.Views.Dialogs.CapstoneEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Capstone"
        Width="420" Height="330"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name + Glyph row -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="64"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Name" Foreground="{StaticResource DimBrush}" FontSize="10" Margin="0,0,0,2"/>
                <TextBox x:Name="NameBox" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Sigil" Foreground="{StaticResource DimBrush}" FontSize="10" Margin="0,0,0,2"/>
                <TextBox x:Name="GlyphBox" FontSize="20" TextAlignment="Center"
                         FontFamily="Segoe UI Symbol"/>
            </StackPanel>
        </Grid>

        <!-- Orbital ring string -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Orbital Ring  (8 symbols)" Foreground="{StaticResource DimBrush}"
                       FontSize="10" Margin="0,0,0,2"/>
            <TextBox x:Name="RingBox" FontSize="16" TextAlignment="Center"
                     FontFamily="Segoe UI Symbol" MaxLength="8"/>
        </StackPanel>

        <!-- Description label -->
        <TextBlock Grid.Row="2" Text="Description" Foreground="{StaticResource DimBrush}"
                   FontSize="10" Margin="0,0,0,2"/>

        <!-- Description text area -->
        <TextBox Grid.Row="3" x:Name="DescBox"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="10" Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="72" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Save"   Width="72" Click="OK_Click"/>
        </StackPanel>
    </Grid>
</Window>
