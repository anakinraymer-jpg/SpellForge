{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "SpellForge (Debug)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/SpellForge.WPF/SpellForge/bin/Debug/net10.0-windows/SpellForge.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole",
            "exceptionOptions": [
                {
                    "path": [{ "names": ["System.Exception"] }],
                    "breakMode": "unhandled"
                }
            ]
        }
    ]
}
